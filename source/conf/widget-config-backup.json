{
  "version": "1.0.0",
  "_comment": "Widget 配置文件 · 修改后刷新页面即生效，无需重新编译",
  "widgets": [
    {
      "_comment": "=== Google 同意弹窗（全站，最高优先级）===",
      "id": "google-consent",
      "enabled": true,
      "priority": 100,
      "type": "script",
      "src": "https://consent.google.com/script.js",
      "attrs": {
        "data-callback": "onConsentCallback"
      },
      "match": {
        "path": ["*"]
      },
      "trigger": {
        "type": "onload",
        "delay": 0
      }
    },

    {
      "_comment": "=== Google AdSense 文章底部广告 ===",
      "id": "article-bottom-ad",
      "enabled": true,
      "priority": 50,
      "type": "html",
      "content": "<div class='wr-ad-wrap' style='margin:2rem 0;text-align:center;'><ins class='adsbygoogle' style='display:block' data-ad-client='ca-pub-XXXXXXXX' data-ad-slot='1234567890' data-ad-format='auto'></ins><script>(adsbygoogle = window.adsbygoogle || []).push({});<\/script></div>",
      "inject": {
        "selector": "#article-end",
        "position": "beforeend"
      },
      "match": {
        "path": ["/blog/*", "/post/*", "/article/*"],
        "device": ["mobile", "desktop"]
      },
      "trigger": {
        "type": "visible",
        "delay": 0
      }
    },

    {
      "_comment": "=== 移动端分享按钮（文章页，AB Test 50%）===",
      "id": "share-button-mobile",
      "enabled": true,
      "priority": 30,
      "type": "html",
      "content": "<button onclick=\"navigator.share && navigator.share({title:document.title,url:location.href})\" style=\"position:fixed;bottom:20px;right:20px;z-index:999;background:#6B5CE7;color:#fff;border:none;border-radius:50%;width:48px;height:48px;font-size:20px;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.2)\" aria-label=\"分享\">↑</button>",
      "inject": {
        "selector": "body",
        "position": "beforeend"
      },
      "match": {
        "path": ["/post/*", "/blog/*"],
        "device": ["mobile"]
      },
      "trigger": {
        "type": "idle",
        "delay": 2000
      },
      "experiment": {
        "key": "share_btn_v1",
        "ratio": 0.5
      }
    },

    {
      "_comment": "=== 全局公告横幅（首页+列表页，工作时间显示）===",
      "id": "announcement-banner",
      "enabled": false,
      "priority": 80,
      "type": "html",
      "content": "<div id='wr-banner' style='background:#6B5CE7;color:#fff;text-align:center;padding:10px;font-size:14px;'>🎉 新功能上线！<a href='/new-feature' style='color:#fff;text-decoration:underline;margin-left:8px;'>了解详情</a><span onclick=\"document.getElementById('wr-banner').remove()\" style='float:right;cursor:pointer;padding:0 12px;'>✕</span></div>",
      "inject": {
        "selector": "body",
        "position": "afterbegin"
      },
      "match": {
        "path": ["/", "/list/*"],
        "device": ["mobile", "desktop"],
        "timeRange": [9, 22]
      },
      "trigger": {
        "type": "onload",
        "delay": 0
      }
    },

    {
      "_comment": "=== 全局自定义样式注入 ===",
      "id": "global-promo-style",
      "enabled": false,
      "priority": 10,
      "type": "style",
      "content": ".promo-banner { display: block !important; } .promo-badge::after { content: ' 🔥'; }",
      "match": {
        "path": ["*"]
      },
      "trigger": {
        "type": "onload",
        "delay": 0
      }
    },

    {
      "_comment": "=== 第三方客服脚本（空闲时加载，减少首屏影响）===",
      "id": "customer-chat",
      "enabled": true,
      "priority": 5,
      "type": "script",
      "src": "https://your-chat-service.com/widget.js",
      "match": {
        "path": ["*"],
        "device": ["desktop"]
      },
      "trigger": {
        "type": "idle",
        "delay": 3000
      }
    },
    {
      "_comment": "=== 文章顶部广告图片 ===",
      "id": "adtop-image",
      "enabled": true,
      "priority": 60,
      "type": "html",
      "content": "<div style='text-align:center;margin:1rem 0;'><a href='https://apps.apple.com/us/app/nicasa-image-viewer/id6756032669?mt=12' target='_blank'><img src='/conf/nicasa.png' alt='广告' style='max-width:100%;height:auto;' /></a></div>",
      "inject": {
        "selector": "#adtop",
        "position": "beforeend"
      },
      "match": {
        "path": ["*"],
        "device": ["mobile", "desktop"]
      },
      "trigger": {
        "type": "onload",
        "delay": 0
      }
    },

    {
      "_comment": "=== 文章底部广告图片 ===",
      "id": "adbottom-image",
      "enabled": true,
      "priority": 55,
      "type": "html",
      "content": "<div style='text-align:center;margin:1rem 0;'><a href='https://apps.apple.com/us/app/nicasa-image-viewer/id6756032669?mt=12' target='_blank'><img src='/conf/nicasa.png' alt='广告' style='max-width:100%;height:auto;' /></a></div>",
      "inject": {
        "selector": "#adbottom",
        "position": "beforeend"
      },
      "match": {
        "path": ["*"],
        "device": ["mobile", "desktop"]
      },
      "trigger": {
        "type": "onload",
        "delay": 0
      }
    }
  ]
}
